<?xml version="1.0" encoding="UTF-8"?>
<window>
    <defaultcontrol always="true">3110</defaultcontrol>
    <controls>
        <control type="image">
            <left>0</left><top>0</top><width>1920</width><height>1080</height>
            <texture colordiffuse="E6000000">colors/white.png</texture>
        </control>

        <control type="group">
            <centerleft>50%</centerleft><centertop>50%</centertop>
            <width>1800</width><height>950</height>
            <control type="image">
                <width>1800</width><height>950</height>
                <texture colordiffuse="FF000000">colors/white.png</texture>
                <bordertexture border="4">overlays/shadow.png</bordertexture>
                <bordersize>4</bordersize>
            </control>

            <control type="image">
                <width>1800</width><height>70</height>
                <texture colordiffuse="FFFFB612">colors/white.png</texture>
            </control>
            <control type="label">
                <width>1800</width><height>70</height>
                <font>font52_title</font><textcolor>black</textcolor>
                <label>Pick a Color...Any Color</label>
                <align>center</align>
            </control>

            <control type="panel" id="3110">
                <left>20</left><top>100</top>
                <width>1400</width><height>780</height>
                <onright>3012</onright>
                <orientation>vertical</orientation>
                <itemlayout height="70" width="200">
                    <control type="image">
                        <left>5</left><top>5</top><width>190</width><height>60</height>
                        <texture colordiffuse="FF222222">colors/white.png</texture>
                    </control>
                    <control type="image">
                        <left>15</left><top>15</top><width>40</width><height>40</height>
                        <texture border="2">$INFO[ListItem.Icon]</texture>
                    </control>
                    <control type="label">
                        <left>60</left><top>5</top><width>130</width><height>60</height>
                        <font>font10</font><textcolor>white</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </itemlayout>
                <focusedlayout height="70" width="200">
                    <control type="image">
                        <left>5</left><top>5</top><width>190</width><height>60</height>
                        <texture colordiffuse="FFFFB612">colors/white.png</texture>
                    </control>
                    <control type="image">
                        <left>15</left><top>15</top><width>40</width><height>40</height>
                        <texture border="2">$INFO[ListItem.Icon]</texture>
                    </control>
                    <control type="label">
                        <left>60</left><top>5</top><width>130</width><height>60</height>
                        <font>font10</font><textcolor>black</textcolor>
                        <label>$INFO[ListItem.Label]</label>
                    </control>
                </focusedlayout>
            </control>

            <control type="group">
                <left>1450</left><top>100</top>
                <control type="image">
                    <width>320</width><height>150</height>
                    <texture colordiffuse="$INFO[Window.Property(colorstring)]">colors/white.png</texture>
                </control>
                <control type="label">
                    <top>160</top><width>320</width>
                    <font>font20_title</font><align>center</align>
                    <label>$INFO[Window.Property(colorstring)]</label>
                </control>
				
				<control type="grouplist" id="3000">
                    <top>220</top><width>320</width><itemgap>15</itemgap>
                    <onleft>3110</onleft>
                    <onright>3110</onright>
                    <control type="button" id="3012">
                        <width>320</width><height>60</height>
                        <texturefocus colordiffuse="FFFFB612">colors/white.png</texturefocus>
                        <texturenofocus colordiffuse="FF222222">colors/white.png</texturenofocus>
                        <label>Apply and Save</label>
                        <align>center</align>
                        <onleft>3110</onleft>
                        <onup>3011</onup>
                        <ondown>3010</ondown>
                    </control>
                    <control type="button" id="3010">
                        <width>320</width><height>60</height>
                        <texturefocus colordiffuse="FFFFB612">colors/white.png</texturefocus>
                        <texturenofocus colordiffuse="FF222222">colors/white.png</texturenofocus>
                        <label>Enter Kodi Color Code</label>
                        <align>center</align>
                        <onleft>3110</onleft>
                        <onup>3012</onup>
                        <ondown>3015</ondown>
                    </control>
                    <control type="label">
                        <width>320</width><height>30</height>
                        <font>font12</font><textcolor>grey</textcolor>
                        <label>Change Opacity</label><align>center</align>
                    </control>
                    <control type="slider" id="3015">
                        <width>320</width><height>40</height>
                        <texturesliderbar colordiffuse="FF222222">colors/white.png</texturesliderbar>
                        <textureslidernib colordiffuse="FF888888">colors/white.png</textureslidernib>
                        <onleft>3110</onleft>
                        <onup>3010</onup>
                        <ondown>3011</ondown>
                    </control>
                    <control type="button" id="3011">
                        <width>320</width><height>60</height>
                        <texturefocus colordiffuse="FFFFB612">colors/white.png</texturefocus>
                        <texturenofocus colordiffuse="FF222222">colors/white.png</texturenofocus>
                        <label>Reset to Default</label>
                        <align>center</align>
                        <onleft>3110</onleft>
                        <onup>3015</onup>
                        <ondown>3012</ondown>
                    </control>
                </control>
            </control>
        </control>
    </controls>
</window>